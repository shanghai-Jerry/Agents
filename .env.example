# ============================================
# Agent System - Environment Variables
# ============================================
# Copy this file to .env and fill in your API keys.

# --- LLM Model API Keys ---

# Anthropic (Claude) - Primary model for orchestrator and sub-agents
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (GPT) - Used for summarization and fallback tasks
OPENAI_API_KEY=your_openai_api_key_here

# Google (Gemini) - Alternative model option
# GOOGLE_API_KEY=your_google_api_key_here

# --- DeepSeek (OpenAI-compatible) ---
# DeepSeek uses OpenAI-compatible API. Set OPENAI_API_KEY and OPENAI_API_BASE:
# OPENAI_API_KEY=your_deepseek_api_key_here
# OPENAI_API_BASE=https://api.deepseek.com
# PRIMARY_MODEL=deepseek-chat        # or deepseek-reasoner

# --- Model Configuration ---
# Supports aliases: claude-sonnet-4-5, claude-opus-4, gpt-4o, gemini-2.5-pro, etc.
# Or full format: anthropic:claude-sonnet-4-5-20250929, openai:gpt-4o, google_genai:gemini-2.5-pro-preview-06-05
PRIMARY_MODEL=claude-sonnet-4-5
SUBAGENT_MODEL=claude-sonnet-4-5
RESEARCH_MODEL=claude-sonnet-4-5
FALLBACK_MODEL=gpt-4o-mini
MODEL_TEMPERATURE=0.0

# --- Tools ---

# Tavily - Web search tool (needed for research sub-agent)
TAVILY_API_KEY=your_tavily_api_key_here

# --- SSE Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Observability ---

# LangSmith - Tracing and monitoring (required for langgraph dev)
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_PROJECT=agents
# LANGSMITH_TRACING=true

# --- Application ---

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
